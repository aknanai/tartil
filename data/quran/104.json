04:8","text":{"hafs":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","warsh":"إِنَّهَا عَلَيْهِم مُّوصَدَةٞ"},"words":{"hafs":["إِنَّهَا","عَلَيْهِم","مُّؤْصَدَةٌ"],"warsh":["إِنَّهَا","عَلَيْهِم","مُّوصَدَةٞ"]},"sajda":false},{"n":9,"key":"104:9","text":{"hafs":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","warsh":"فِے عَمَدٖ مُّمَدَّدَةٍۖ"},"words":{"hafs":["فِى","عَمَدٍ","مُّمَدَّدَةٍۭ"],"warsh":["فِے","عَمَدٖ","مُّمَدَّدَةٍۖ"]},"sajda":false}]}